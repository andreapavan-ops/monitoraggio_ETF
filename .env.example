# ETF Monitor System - Configurazione ambiente
# Copia questo file in .env e compila i valori

# ── Email (Resend API) ──────────────────────────────────────────────────────
# Ottieni la API key su https://resend.com (piano gratuito: 3000 email/mese)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Mittente: usa onboarding@resend.dev per test,
# oppure configura il tuo dominio su Resend
EMAIL_SENDER=onboarding@resend.dev

# Destinatario degli alert
EMAIL_RECIPIENT=andreapavan67@gmail.com

# ── Database PostgreSQL (Railway) ───────────────────────────────────────────
# Railway lo inietta automaticamente, non serve in locale se usi SQLite
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Scheduler ───────────────────────────────────────────────────────────────
MONITOR_HOUR=18
MONITOR_MINUTE=0

# Esegui il monitoraggio anche all'avvio (true/false)
RUN_ON_START=true
